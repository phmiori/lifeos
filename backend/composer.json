{
    "name": "lifeos/backend",
    "description": "LifeOS Backend API — PHP 8.2 + Slim 4 + PostgreSQL",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "firebase/php-jwt": "^6.9",
        "james-heinrich/getid3": "^1.9",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
}